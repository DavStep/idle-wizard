{
  "name": "idle-wizard",
  "version": "0.2.92",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:atlas": "node scripts/build-asset-atlas.js",
    "local:keepalive": "node scripts/local-runtime.js start",
    "local:keepalive:status": "node scripts/local-runtime.js status",
    "local:keepalive:stop": "node scripts/local-runtime.js stop",
    "predev": "npm run assets:atlas",
    "dev": "vite --host 0.0.0.0 --port 55173 --strictPort",
    "dev:status": "sh -c 'lsof -nP -sTCP:LISTEN -iTCP:55173 || true; ps -axo pid=,ppid=,stat=,command= | grep \"$PWD/node_modules/.bin/vite\" | grep -v grep || true'",
    "dev:kill": "sh -c 'ps -axo pid=,command= | while read pid command; do case \"$command\" in *\"$PWD/node_modules/.bin/vite\"*) test \"$pid\" = \"$$\" || kill \"$pid\" ;; esac; done; pids=$(lsof -tiTCP:55173 -sTCP:LISTEN); test -z \"$pids\" || kill $pids'",
    "build": "npm run build:prod --",
    "prebuild:dev": "npm run assets:atlas",
    "build:dev": "vite build --mode development",
    "prebuild:prod": "npm run assets:atlas",
    "build:prod": "vite build --mode production",
    "preview": "vite preview --host 0.0.0.0 --port 55174 --strictPort",
    "lint": "eslint .",
    "test": "vitest run",
    "check:ui": "node scripts/check-ui-consistency.mjs",
    "check": "npm run lint && npm test && npm run build",
    "release": "node scripts/release.js",
    "qa:data:sync": "node scripts/qa-data.js sync --server maincloud --database idle-wizard",
    "qa:data:from-backup": "node scripts/qa-data.js from-backup",
    "balance:sim": "node scripts/balance-sim.js",
    "balance:lab": "node --import ./scripts/register-json-module-loader.mjs scripts/balance-lab.js",
    "tutorial:capture": "node scripts/capture-tutorial-flow.js",
    "mobile:sync": "npm run mobile:sync:prod",
    "mobile:sync:dev": "npm run build:dev && npx cap sync android",
    "mobile:sync:prod": "npm run build:prod && npx cap sync android",
    "android:add": "npx cap add android",
    "android:open": "npx cap open android",
    "android:run": "npm run android:run:dev",
    "android:run:dev": "npm run build:dev && npx cap run android",
    "android:run:prod": "npm run build:prod && npx cap run android",
    "android:assembleDebug": "npm run mobile:sync:dev && cd android && ./gradlew assembleDebug",
    "android:assembleProdDebug": "npm run mobile:sync:prod && cd android && ./gradlew assembleDebug",
    "android:assembleRelease": "npm run mobile:sync:prod && cd android && ./gradlew assembleRelease",
    "android:postDebugDiscord": "npm run android:assembleProdDebug && node scripts/post-apk-discord.js android/app/build/outputs/apk/debug/app-debug.apk",
    "discord:postApk": "node scripts/post-apk-discord.js",
    "android:clean": "cd android && ./gradlew clean",
    "stdb:start": "PATH=\"$HOME/.local/bin:$PATH\" spacetime start",
    "stdb:build": "PATH=\"$HOME/.local/bin:$PATH\" spacetime build --module-path ./spacetimedb",
    "stdb:publish": "PATH=\"$HOME/.local/bin:$PATH\" spacetime publish idle-wizard --server local --module-path ./spacetimedb",
    "stdb:publish:maincloud": "PATH=\"$HOME/.local/bin:$PATH\" spacetime publish idle-wizard --server maincloud --module-path ./spacetimedb --delete-data=never",
    "stdb:generate": "PATH=\"$HOME/.local/bin:$PATH\" spacetime generate --lang typescript --out-dir ./src/backend/spacetimedb/module_bindings --module-path ./spacetimedb",
    "stdb:dev": "PATH=\"$HOME/.local/bin:$PATH\" spacetime dev idle-wizard --server local --yes --module-path ./spacetimedb --module-bindings-path ./src/backend/spacetimedb/module_bindings --run \"npm run dev\""
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@esotericsoftware/spine-pixi-v8": "^4.3.7",
    "@fontsource/lexend": "^5.2.11",
    "bitecs": "^0.4.0",
    "oidc-client-ts": "^3.5.0",
    "pixi.js": "^8.19.0",
    "spacetimedb": "2.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "jsdom": "^29.1.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  },
  "description": "JavaScript mobile game with a full ECS gameplay layer, room-view UI, Vite client, Capacitor Android package, and SpacetimeDB backend.",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavStep/idle-wizard.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DavStep/idle-wizard/issues"
  },
  "homepage": "https://github.com/DavStep/idle-wizard#readme"
}
