{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_policy.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking Idle Wizard tool policy"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/user_prompt_submit_context.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking Idle Wizard prompt context"
          }
        ]
      }
    ]
  }
}
